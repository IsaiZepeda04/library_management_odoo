<odoo>
    <record id="view_partner_from_library_member" model="ir.ui.view">
        <field name="name">res.partner.from.library.member</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">

                <xpath expr="//sheet//group" position="inside">
                <group string="Library">
                    <field name="is_library_member"/>
                    <field name="member_code" readonly="1"/>
                    <field name="member_date"/>
                </group>
            </xpath>
        </field>
    </record>

    <record id="action_library_members" model="ir.actions.act_window">
        <field name="name">Library Member</field>
        <field name="res_model">res.partner</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('is_library_member', '=', True)]</field>
        <field name="context">{'default_is_library_member': True}</field>
    </record>
</odoo>