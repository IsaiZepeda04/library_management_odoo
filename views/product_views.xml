<odoo>
    <record id="view_product_template_form_library_inherit" model="ir.ui.view">
        <field name="name">product.template.form.library.inherit</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet//group" position="inside">
                <group string="Biblioteca">
                    <field name="is_library_item"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>