<odoo>
    <record id="module_category_library_management" model="ir.module.category">
    <field name="name">Library Management</field>
    <field name="sequence">25</field>
</record>

    <record id="group_library_librarian" model="res.groups">
        <field name="name">Bibliotecario</field>
        <field name="comment">Control total sobre libros, socios y prestamos.</field>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_library_public_user" model="res.groups">
        <field name="name">Usuario Publico</field>
        <field name="comment">Solo puede ver libros disponibles.</field>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>
</odoo>